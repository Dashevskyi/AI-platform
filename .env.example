# Database
DATABASE_URL=postgresql+asyncpg://ai_platform:ai_platform_secret@localhost:5432/ai_platform

# Auth
SECRET_KEY=change-me-to-random-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Encryption key for provider API keys (Fernet, base64-encoded 32 bytes)
ENCRYPTION_KEY=change-me-generate-with-python-cryptography-fernet

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible local/remote inference, for example vLLM on a GPU host
TEST_OPENAI_BASE_URL=http://172.10.100.9:8000/v1
TEST_OPENAI_MODEL=qwen2.5-32b

INVENTORY_DATABASE_URL=postgresql+asyncpg://readonly_user:readonly_password@inventory-db:5432/inventory

# Admin seed
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin

# Log retention days
LOG_RETENTION_DAYS=90
